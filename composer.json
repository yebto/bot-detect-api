{
    "name": "yebto/bot-detect-api",
    "description": "PHP SDK for the YEB Bot Detection API. Detect bots, crawlers and automated traffic.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "yeb",
        "api",
        "sdk",
        "laravel",
        "php",
        "bot",
        "detect",
        "crawler",
        "security"
    ],
    "homepage": "https://yeb.to",
    "support": {
        "email": "support@yeb.to",
        "issues": "https://github.com/yebto/bot-detect-api/issues",
        "source": "https://github.com/yebto/bot-detect-api"
    },
    "authors": [
        {
            "name": "NETOX Ltd.",
            "email": "support@yeb.to",
            "homepage": "https://yeb.to",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.1",
        "yebto/api-client": "^1.0"
    },
    "suggest": {
        "illuminate/support": "Required for Laravel Facade & ServiceProvider integration (^10.0|^11.0|^12.0)"
    },
    "autoload": {
        "psr-4": {
            "Yebto\\BotDetectAPI\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Yebto\\BotDetectAPI\\BotDetectAPIServiceProvider"
            ],
            "aliases": {
                "BotDetectAPI": "Yebto\\BotDetectAPI\\Facades\\BotDetectAPI"
            }
        }
    }
}
